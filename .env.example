# =============================================================================
# Crypto Stacker - Frontend Environment Variables
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# =============================================================================

# Backend API URL
# Development: leave empty (Vite proxy forwards /api to localhost:8000)
# Production: set your Django server URL, e.g. https://api.yourdomain.com
VITE_API_BASE_URL=

# App name shown in browser tab (optional)
VITE_APP_NAME=Crypto Stacker
