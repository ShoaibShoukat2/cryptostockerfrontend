# =============================================================================
# Crypto Stacker - Frontend Environment Variables
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# =============================================================================

# Backend API URL
# Development (local Django): leave empty — Vite proxy forwards /api to localhost:8000
# Production (PythonAnywhere): https://cryptostacker.pythonanywhere.com/api
VITE_API_BASE_URL=https://cryptostacker.pythonanywhere.com/api

# App name shown in browser tab (optional)
VITE_APP_NAME=Crypto Stacker
